{
  "Serilog": {
    "MinimumLevel": {
      // Default level for all code not covered by the overrides below.
      "Default": "Information",
      "Override": {
        // Suppress noisy Microsoft framework logs — only show warnings and above.
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    // These enrichers add extra properties to every log entry.
    // They are applied at runtime — must match packages installed in the API project.
    "Enrich": [
      "FromLogContext", // picks up LogContext.PushProperty(...) scoped properties
      "WithMachineName", // adds the server's hostname
      "WithThreadId" // adds the thread ID (useful for async debugging)
    ],
    "Properties": {
      // A static property added to every log entry — useful for filtering in dashboards.
      "Application": "ECommerce API"
    }
  },

  // CloudinarySettings is gone from here — 
  //  moving to [Required] + ValidateOnStart() below means it doesn't 
  //  need placeholder keys in the file at all; 
  // if it's missing in any environment, the app refuses to start with a clear error 
  //  instead of silently running with empty strings


  "Logging": {
    // This is the built-in .NET logging config — kept as fallback only.
    // Serilog takes over all logging once builder.Host.UseSerilog() is called.
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HealthChecksSettings": {
    "TimeoutSeconds": 3 // Default timeout for health checks
  },
  "AllowedHosts": "*"
}
