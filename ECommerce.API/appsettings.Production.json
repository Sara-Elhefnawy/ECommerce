{
  "Serilog": {
    "MinimumLevel": {
      // In Production, only log Information and above — Debug is too noisy.
      "Default": "Information",
      "Override": {
        // Suppress framework internals completely in Production.
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=prod-sql-host;Database=ECommerceSystem;...",
    // Production PostgreSQL log database — use a dedicated user with INSERT-only permissions.
    "LogsDb": "Host=production-db-host;Database=ecommerce_logs;Username=ecommerce_logger;Password=...;SSL Mode=Require;"
  },
  "AllowedHosts": "*"
}
