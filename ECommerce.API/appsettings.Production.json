{
  "Serilog": {
    "MinimumLevel": {
      // In Production, only log Information and above — Debug is too noisy.
      "Default": "Information",
      "Override": {
        // Suppress framework internals completely in Production.
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
