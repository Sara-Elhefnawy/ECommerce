{
  "Serilog": {
    "MinimumLevel": {
      // More verbose in Development — shows Debug logs from your own code.
      "Default": "Debug",
      "Override": {
        // Show EF Core SQL queries (Information shows the actual SQL).
        "Microsoft.EntityFrameworkCore": "Information",
        // Show ASP.NET routing and middleware info.
        "Microsoft.AspNetCore": "Information",
        "Microsoft": "Information",
        // Show audit interceptor debug logs (entity state changes).
        "ECommerce.Infrastructure.Interceptors": "Debug"
      }
    }
  },
  "AllowedHosts": "*"
}
