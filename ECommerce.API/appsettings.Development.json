{
  "Serilog": {
    "MinimumLevel": {
      // More verbose in Development — shows Debug logs from your own code.
      "Default": "Debug",
      "Override": {
        // Show EF Core SQL queries (Information shows the actual SQL).
        "Microsoft.EntityFrameworkCore": "Information",
        // Show ASP.NET routing and middleware info.
        "Microsoft.AspNetCore": "Information",
        "Microsoft": "Information",
        // Show audit interceptor debug logs (entity state changes).
        "ECommerce.Infrastructure.Interceptors": "Debug"
      }
    }
  },

  "ConnectionStrings": {
    // Main SQL Server database for the application data (products, brands, types).
    "DefaultConnection": "Server=DESKTOP-JJ4VVTI;Database=ECommerceSystem;Trusted_Connection=True;TrustServerCertificate=True;",
    // Separate PostgreSQL database used exclusively for storing Serilog log entries.
    "LogsDb": "Host=127.0.0.1;Database=ecommerce_logs_dev;Username=postgres;Password=148951;"
  },
  "AllowedHosts": "*"
}
